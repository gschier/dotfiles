#!/usr/bin/env bash

set -euo pipefail

on_ac_power() {
  local supply type_file online_file status_file type online status

  for supply in /sys/class/power_supply/*; do
    type_file="$supply/type"
    online_file="$supply/online"
    status_file="$supply/status"

    if [[ -r "$type_file" ]]; then
      type=$(<"$type_file")
      if [[ "$type" == "Mains" && -r "$online_file" ]]; then
        online=$(<"$online_file")
        [[ "$online" == "1" ]] && return 0
      fi
    fi

    if [[ -r "$status_file" ]]; then
      status=$(<"$status_file")
      if [[ "$status" == "Charging" || "$status" == "Full" ]]; then
        return 0
      fi
    fi
  done

  return 1
}

on_ac_power && exit 0
exec "$@"
