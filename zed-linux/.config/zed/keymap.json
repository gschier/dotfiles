[
  {
    "bindings": {
      "super-[": "pane::GoBack",
      "super-]": "pane::GoForward",
      "ctrl-!": "pane::RevealInProjectPanel",
      "ctrl-E": "tab_switcher::ToggleAll",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-r": "task::Rerun",
      "shift-enter": ["terminal::SendText", "\u001b\r"],
    },
  },
  {
    "context": "VimControl && !menu",
    "bindings": {
      "e": "vim::Up",
      "n": "vim::Down",
      "i": "vim::Right",
      "shift-n": "vim::JoinLines",
      "shift-j": "search::SelectPreviousMatch",
      "s": "vim::InsertBefore",
      "j": "search::SelectNextMatch",
      "space": "vim::InsertBefore",
    },
  },
  {
    "context": "vim_mode == normal",
    "bindings": {
      "space f f": "file_finder::Toggle",
      "space f b": "tab_switcher::Toggle",
      "space e": "editor::GoToDiagnostic",
      "space E": "editor::GoToPreviousDiagnostic",
      "g f f": "editor::Format",
      "g c c": "editor::ToggleComments",
      "g a": "editor::ToggleCodeActions",
    },
  },
  {
    "context": "Editor",
    "bindings": {
      "ctrl-j": "editor::Hover",
    },
  },
  {
    "context": "!Terminal",
    "bindings": {
      "ctrl-shift-space": "terminal_panel::ToggleFocus",
    },
  },
  {
    "context": "Terminal",
    "bindings": {
      "ctrl-shift-space": "terminal_panel::Toggle",
    },
  },
  {
    "context": "AgentPanel",
    "bindings": {
      "ctrl-?": "workspace::ToggleRightDock",
    },
  },
  {
    "context": "Workspace",
    "bindings": {
      "alt-shift-r": [
        "task::Spawn",
        {
          "reveal_target": "dock",
        },
      ],
    },
  },
]
