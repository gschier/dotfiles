#!/usr/bin/env bash

set -euo pipefail

repo_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
expected_repo_dir="$HOME/Workspace/dotfiles"

if [[ "$repo_dir" != "$expected_repo_dir" || ! -d "$repo_dir/.git" ]]; then
	echo "Run this from a dotfiles checkout at $expected_repo_dir." >&2
	echo >&2
	echo "Bootstrap with:" >&2
	echo "  sudo dnf install -y git" >&2
	echo "  mkdir -p ~/Workspace" >&2
	echo "  git clone https://github.com/gschier/dotfiles.git ~/Workspace/dotfiles" >&2
	echo "  cd ~/Workspace/dotfiles" >&2
	echo "  ./scripts/install-fedora-niri" >&2
	exit 1
fi

install_pkg() {
	if ! rpm -q "$1" >/dev/null 2>&1; then
		echo "Installing $1"
		sudo dnf install -y "$1"
	else
		echo "Already installed $1"
	fi
}

install_pkg_no_weak_deps() {
	if ! rpm -q "$1" >/dev/null 2>&1; then
		echo "Installing $1 without weak dependencies"
		sudo dnf install -y --setopt=install_weak_deps=False "$1"
	else
		echo "Already installed $1"
	fi
}

install_cmd() {
	local check_bin="$1"
	shift

	if ! command -v "$check_bin" >/dev/null 2>&1; then
		echo "Installing $check_bin..."
		"$@"
	else
		echo "Already installed $check_bin"
	fi
}

install_flatpak_app() {
	local app_id="$1"
	local app_name="$2"

	if ! flatpak info "$app_id" >/dev/null 2>&1; then
		echo "Installing $app_name..."
		sudo flatpak remote-add --system --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo
		sudo flatpak install --system -y flathub "$app_id"
	else
		echo "Already installed $app_name"
	fi
}

install_dms() {
	if ! rpm -q dms >/dev/null 2>&1; then
		echo "Installing Dank Material Shell..."
		sudo dnf copr enable -y avengemedia/dms
		sudo dnf install -y dms
	else
		echo "Already installed Dank Material Shell"
	fi
}

install_dms_plugin() {
	local plugin_id="$1"

	if ! dms plugins list | grep -q "ID: $plugin_id"; then
		echo "Installing DMS plugin $plugin_id..."
		dms plugins install "$plugin_id"
	else
		echo "Already installed DMS plugin $plugin_id"
	fi
}

install_packer() {
	local packer_dir="$HOME/.local/share/nvim/site/pack/packer/start/packer.nvim"

	if [[ ! -d "$packer_dir/.git" ]]; then
		echo "Installing packer.nvim..."
		git clone --depth 1 https://github.com/wbthomason/packer.nvim "$packer_dir"
	else
		echo "Already installed packer.nvim"
	fi
}

install_1password() {
	if ! rpm -q 1password >/dev/null 2>&1; then
		echo "Installing 1Password..."
		sudo rpm --import https://downloads.1password.com/linux/keys/1password.asc
		sudo tee /etc/yum.repos.d/1password.repo >/dev/null <<'EOF'
[1password]
name=1Password Stable Channel
baseurl=https://downloads.1password.com/linux/rpm/stable/$basearch
enabled=1
gpgcheck=1
repo_gpgcheck=1
gpgkey="https://downloads.1password.com/linux/keys/1password.asc"
EOF
		sudo dnf install -y 1password
	else
		echo "Already installed 1Password"
	fi
}

install_stripe() {
	if ! command -v stripe >/dev/null 2>&1; then
		echo "Installing Stripe CLI..."
		sudo tee /etc/yum.repos.d/stripe.repo >/dev/null <<'EOF'
[Stripe]
name=stripe
baseurl=https://packages.stripe.dev/stripe-cli-rpm-local/
enabled=1
gpgcheck=0
EOF
		sudo dnf install -y stripe
	else
		echo "Already installed Stripe CLI"
	fi
}

install_tailscale() {
	install_pkg tailscale
	sudo systemctl enable --now tailscaled
}

install_docker() {
	echo "Installing Docker and Compose..."
	install_pkg moby-engine
	install_pkg docker-compose

	sudo systemctl enable --now docker

	sudo groupadd -f docker
	if ! id -nG "$USER" | grep -qw docker; then
		echo "Adding $USER to docker group..."
		sudo usermod -aG docker "$USER"
		echo "Run 'newgrp docker' to use Docker in this terminal without logging out."
	else
		echo "Already in docker group"
	fi
}

install_air() {
	local air_bin="$HOME/.local/bin/air"

	if command -v air >/dev/null 2>&1 || [[ -x "$air_bin" ]]; then
		echo "Already installed Air"
		return
	fi

	echo "Installing Air..."
	mkdir -p "$HOME/.local/bin"
	GOBIN="$HOME/.local/bin" go install github.com/air-verse/air@latest
}

install_asdbctl_udev_rule() {
	local rules_file="/etc/udev/rules.d/70-apple-studio-display.rules"
	local rules_content='SUBSYSTEM=="hidraw", ATTRS{idVendor}=="05ac", ATTRS{idProduct}=="1118", TAG+="uaccess"'

	if [[ ! -f "$rules_file" ]] || ! sudo grep -Fxq "$rules_content" "$rules_file"; then
		echo "Installing Apple Studio Display udev rule..."
		printf '%s\n' "$rules_content" | sudo tee "$rules_file" >/dev/null
		sudo udevadm control --reload-rules
		sudo udevadm trigger --subsystem-match=hidraw
	else
		echo "Already installed Apple Studio Display udev rule"
	fi
}

install_asdbctl() {
	local asdbctl_dir="$HOME/Workspace/asdbctl"

	install_asdbctl_udev_rule

	if command -v asdbctl >/dev/null 2>&1; then
		echo "Already installed asdbctl"
		return
	fi

	install_pkg hidapi-devel
	install_pkg pkgconf-pkg-config
	install_pkg systemd-devel

	# Make cargo available in this non-interactive install script immediately after rustup install.
	# shellcheck source=/dev/null
	source "$HOME/.cargo/env"

	if [[ ! -d "$asdbctl_dir/.git" ]]; then
		echo "Cloning asdbctl..."
		git clone https://github.com/juliuszint/asdbctl.git "$asdbctl_dir"
	else
		echo "Already cloned asdbctl"
	fi

	echo "Building asdbctl..."
	cargo build --release --manifest-path "$asdbctl_dir/Cargo.toml"
	sudo install -Dm755 "$asdbctl_dir/target/release/asdbctl" /usr/local/bin/asdbctl
}

install_development_dependencies() {
	echo "Installing development dependencies..."

	# Tauri's Fedora prerequisites for Linux desktop app development.
	sudo dnf group install -y "c-development"
	install_pkg file
	install_pkg libappindicator-gtk3-devel
	install_pkg librsvg2-devel
	install_pkg libxdo-devel
	install_pkg openssl-devel
	install_pkg webkit2gtk4.1-devel

	# Rust native crates used by Yaak and other local tools.
	install_pkg cmake
	install_pkg expat-devel
	install_pkg pkgconf-pkg-config

	# Yaak vendors OpenSSL on Linux, which builds OpenSSL from source.
	install_pkg perl-FindBin
	install_pkg perl-IPC-Cmd
}

install_system_dconf() {
	echo "Installing system dconf defaults..."
	sudo install -Dm644 \
		"$repo_dir/system/etc/dconf/db/local.d/00-interface" \
		/etc/dconf/db/local.d/00-interface
	sudo dconf update
}

echo "Updating dependencies..."
sudo dnf update -y

echo "Creating ~/Workspace..."
mkdir -p ~/Workspace

echo "Installing dependencies..."
install_pkg_no_weak_deps niri
install_pkg greetd
install_pkg tuigreet
install_pkg gnome-keyring
install_pkg xdg-desktop-portal
install_pkg xdg-desktop-portal-gnome
install_pkg xdg-desktop-portal-gtk
install_pkg curl
install_pkg gcc
install_pkg git
install_pkg gh
install_pkg golang
install_pkg google-noto-color-emoji-fonts
install_pkg jq
install_pkg logiops
install_pkg make
install_pkg neovim
install_pkg rofimoji
install_pkg stow
install_pkg twitter-twemoji-fonts
install_pkg dbus-devel
install_pkg flatpak
install_pkg wget
install_pkg wofi
install_pkg wtype
install_docker
install_development_dependencies
install_cmd rustup \
	bash -c 'curl --proto "=https" --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y'
install_air
install_dms
install_dms_plugin calculator

echo "Linking dotfiles..."
"$repo_dir/scripts/install"
install_system_dconf

echo "Installing logiops config..."
sudo install -Dm644 "$repo_dir/system/etc/logid.cfg" /etc/logid.cfg
sudo systemctl enable --now logid

install_packer

echo "Syncing Neovim plugins..."
nvim --headless -u NONE \
	-c 'packadd packer.nvim' \
	-c "luafile $repo_dir/nvim/.config/nvim/lua/gschier/packer.lua" \
	-c 'autocmd User PackerComplete quitall' \
	-c 'PackerSync'

echo "Enabling graphical boot..."
sudo systemctl set-default graphical.target

echo "Setting up greetd..."
sudo tee /etc/greetd/config.toml >/dev/null <<'EOF'
[terminal]
vt = 1
[default_session]
command = "tuigreet --time --remember --cmd niri-session"
user = "greetd"
EOF
sudo systemctl enable greetd

install_cmd vp \
	bash -c 'curl -fsSL https://vite.plus | VP_NODE_MANAGER=yes bash'
install_cmd google-chrome \
	bash -c 'sudo dnf install https://dl.google.com/linux/direct/google-chrome-stable_current_x86_64.rpm'
install_cmd codex \
	bash -c 'vp install -g @openai/codex'
install_cmd omnara \
    bash -c 'curl -fsSL https://omnara.com/install.sh | bash'
install_cmd zed \
	bash -c 'curl -f https://zed.dev/install.sh | sh'
install_cmd railway \
	bash -c 'bash <(curl -fsSL cli.new)'
install_1password
install_stripe
install_tailscale
install_asdbctl
install_flatpak_app org.gnome.World.PikaBackup "Pika Backup"
install_flatpak_app org.telegram.desktop "Telegram Desktop"

echo "Setup Complete"
